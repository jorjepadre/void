{
  "name": "void-agents",
  "version": "0.1.0",
  "description": "AI agent orchestration & harness optimization framework",
  "type": "module",
  "bin": {
    "void": "./dist/bin/void.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch bin/void.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ test/ bin/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "security:audit": "node scripts/security-audit.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.9.1",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "semver": "^7.7.1",
    "yaml": "^2.7.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.14.1",
    "eslint": "^9.25.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "swarm",
    "mcp",
    "claude",
    "void"
  ],
  "license": "MIT"
}
